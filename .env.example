# Next.js app (Neon pooled connection — used by @neondatabase/serverless)
DATABASE_URL=postgresql://user:password@ep-pooler-name-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Python ETL pipeline (Neon direct/unpooled connection — used by billboard_stats/db/connection.py)
# Set these before running the ETL. Values come from the unpooled Neon connection string.
PGHOST=ep-<id>.us-east-1.aws.neon.tech
PGPORT=5432
PGDATABASE=neondb
PGUSER=<neon-user>
PGPASSWORD=<neon-password>
PGSSLMODE=require
